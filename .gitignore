# Rust
target/
**/*.rs.bk

# Go
/bin/
obj/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/
# built engine binary (go build output, not source)
examples/stub-engine/stub-engine

# Environment / Runs
.runs/
.artifacts/
.leaderboard/
.env

# Stray artifacts dropped at repo root when binaries are invoked with
# their default --*-out flags
/telemetry.jsonl
/telemetry-summary.json
/events.jsonl
/contestant_outputs.jsonl
/validation.json
/score.json

# Terraform / OpenTofu (commit .terraform.lock.hcl, ignore the rest)
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Web / Node
node_modules/
web/dist/
*.tsbuildinfo

# MacOS
.DS_Store

# IDEs
.idea/
.vscode/
*.swp
*.swo
/proj_context
# Local secrets — NEVER commit (SSH keys, tokens, etc.)
secrets/
*.pem
*.key

# demo upload artifacts
*.zip
